# MongoDB
MONGO_CONNECTION=mongodb://127.0.0.1:27017/short-link

# API server (Express)
API_PORT=8000
PORT=8000

# Public base URL for generated short links (no trailing slash)
BASE=http://localhost:3000

# Next.js — browser uses same-origin /api via rewrites (leave empty in dev)
NEXT_PUBLIC_API_URL=

# Internal API URL for Next.js rewrites (dev / Docker)
API_INTERNAL_URL=http://localhost:8000

# Auth foundation (not fully implemented)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
COOKIE_NAME=short_link_session
NODE_ENV=development
