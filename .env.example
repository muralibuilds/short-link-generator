# MongoDB — use Atlas in production (Vercel cannot reach 127.0.0.1)
MONGO_CONNECTION=mongodb://127.0.0.1:27017/short-link

# API server (Express) — local dev / Docker only
API_PORT=8000
PORT=8000

# Public base URL for generated short links (no trailing slash)
# Vercel: https://your-app.vercel.app
BASE=http://localhost:3000

# Next.js — browser uses same-origin /api (leave empty)
NEXT_PUBLIC_API_URL=

# Dev-only: Next.js rewrites /api/* to this Express URL.
# Do NOT set on Vercel — production uses pages/api/[...slug].ts instead.
API_INTERNAL_URL=http://localhost:8000

# Optional — override DNS for MongoDB Atlas SRV (Windows/local DNS issues)
# DNS_SERVERS=8.8.8.8,1.1.1.1

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
COOKIE_NAME=short_link_session
NODE_ENV=development
